                      scale_fill_distiller(palette=pal, direction=1, name="Count") +
                      labs(x="Fraction", y="PDB Classification",
                           title="Fraction-by-class heatmap") +
                      theme_classic() +
                      theme(axis.text.x=element_text(angle=30,hjust=1))
                  }
      )
